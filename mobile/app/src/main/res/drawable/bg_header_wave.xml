<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C8601A"/>
        </shape>
    </item>
    <!-- Subtle lighter circle top-right -->
    <item
        android:top="-60dp"
        android:right="-60dp"
        android:bottom="60dp"
        android:left="60dp">
        <shape android:shape="oval">
            <solid android:color="#D4722A"/>
        </shape>
    </item>
    <!-- Subtle darker circle bottom-left -->
    <item
        android:top="60dp"
        android:right="60dp"
        android:bottom="-60dp"
        android:left="-60dp">
        <shape android:shape="oval">
            <solid android:color="#B85518"/>
        </shape>
    </item>
</layer-list>